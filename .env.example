DEBUG=true
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/auth_db
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Password reset
PASSWORD_RESET_EXPIRE_MINUTES=15
FRONTEND_BASE_URL=http://localhost:5173

# SMTP — Gmail example (leave SMTP_HOST empty for console fallback in dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tuamail@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL_FROM=tuamail@gmail.com

# Observability (ADR-012) — traces/metrics shipped to a local Grafana Alloy
# collector (see jinbocho-infrastructure-*/docker/config.alloy), which forwards
# to Grafana Cloud. Leave OTEL_ENABLED=false if you don't run the "observability"
# Compose profile — the service behaves identically either way.
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://alloy:4318
